# Plausible Analytics (privacy-friendly, cookieless)
# Set to 'true' to enable. Domain must be registered at https://plausible.io
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# Leadfeeder / Dealfront Web Visitors (website visitor identification)
# Set to 'true' to enable. Get tracker ID from Dealfront dashboard.
NEXT_PUBLIC_ENABLE_LEADFEEDER=false

# Contact form (Resend email API)
RESEND_API_KEY=
CONTACT_TO_EMAIL=
